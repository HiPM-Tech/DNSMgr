{
  "name": "dnsmgr",
  "version": "1.1.4",
  "private": true,
  "description": "DNS Aggregation Management Platform",
  "scripts": {
    "dev": "concurrently \"pnpm --filter dnsmgr-server dev\" \"pnpm --filter dnsmgr-client dev\"",
    "build": "pnpm --filter dnsmgr-server build && pnpm --filter client build",
    "start": "pnpm --filter dnsmgr-server start"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "@scarf/scarf"
    ]
  }
}
